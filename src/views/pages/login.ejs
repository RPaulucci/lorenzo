<%- include('../layouts/header') %>

<div class="auth-container">
  <div class="auth-card glass-panel">
    <div class="auth-header">
      <h1>Entrar</h1>
      <p>Acesse seu perfil do <strong>lorenzo.mysite.dev.br</strong></p>
    </div>

    <% if (error) { %>
      <div class="alert alert-error">
        <%= error %>
      </div>
    <% } %>

    <form action="/login" method="POST">
      <div class="form-group">
        <label for="identifier">E-mail ou Usuário</label>
        <input type="text" id="identifier" name="identifier" class="form-control" placeholder="Ex: lorenzo ou user@lorenzo.mysite.dev.br" required autocomplete="username">
      </div>

      <div class="form-group">
        <label for="password">Senha</label>
        <input type="password" id="password" name="password" class="form-control" placeholder="Digite sua senha" required autocomplete="current-password">
      </div>

      <button type="submit" class="btn-primary" style="margin-top: 10px;">Entrar no Sistema</button>
    </form>

    <div class="auth-info-box">
      <h4>💡 Modo de Desenvolvimento</h4>
      <p>Caso a API do <strong>lorenzo.mysite.dev.br</strong> não esteja acessível, o sistema está configurado com um serviço simulado (mock). Você pode usar qualquer usuário e senha para entrar!</p>
      <ul style="margin-top: 8px;">
        <li>• Usuário recomendado: <strong>lorenzo</strong></li>
        <li>• Senha recomendada: <strong>lorenzo123</strong></li>
      </ul>
    </div>
  </div>
</div>

<%- include('../layouts/footer') %>
